<view class="page-shell">
  <view class="hero-card">
    <view class="hero-eyebrow">LAIAN CASE LIBRARY</view>
    <view class="hero-title">欢迎回来，{{session.name}}</view>
    <view class="hero-subtitle">当前共维护 {{cases.length}} 个已发布案例。你可以快速筛选、查看详情并直接分享给客户。</view>
    <view class="hero-stats">
      <view class="stat-card" wx:for="{{stats}}" wx:key="label">
        <view class="stat-value">{{item.value}}</view>
        <view class="stat-label">{{item.label}}</view>
      </view>
    </view>
    <view class="notice-strip">当前是设计师工作台，客户通过分享卡片打开后只能查看单个案例详情，不会进入全库。</view>
    <view class="button-row">
      <button class="btn-secondary" bindtap="goEdit">新增案例</button>
      <button class="btn-ghost" bindtap="handleLogout">退出登录</button>
    </view>
  </view>

  <view class="panel">
    <view class="section-header">
      <view>
        <view class="section-title">按户型快速筛选</view>
        <view class="section-subtitle">快速找到更贴近客户需求的空间类型。</view>
      </view>
      <view class="panel-tag">常用入口</view>
    </view>
    <view class="chip-row">
      <view class="chip" wx:for="{{houseTypeChips}}" wx:key="value" bindtap="goList" data-house-type="{{item.value}}">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-header">
      <view>
        <view class="section-title">按材质快速筛选</view>
        <view class="section-subtitle">把客户最关心的主材方案先拿出来看。</view>
      </view>
      <view class="panel-tag">分享高频</view>
    </view>
    <view class="chip-row">
      <view class="chip" wx:for="{{materialChips}}" wx:key="value" bindtap="goList" data-material-type="{{item.value}}">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-header">
      <view>
        <view class="section-title">操作捷径</view>
        <view class="section-subtitle">把常用动作放到同一个工作台里。</view>
      </view>
    </view>
    <view class="icon-grid">
      <view class="action-tile" bindtap="goEdit">
        <view class="action-title">新增案例</view>
        <view class="action-copy">录入固定字段、实景图和自定义模块。</view>
      </view>
      <view class="action-tile" bindtap="goList">
        <view class="action-title">筛选案例</view>
        <view class="action-copy">按户型、材质、标签快速定位可分享内容。</view>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-header">
      <view>
        <view class="section-title">最近案例</view>
        <view class="section-subtitle">点击卡片进入详情页，再直接分享给客户。</view>
      </view>
      <view class="inline-tag">最近更新</view>
    </view>

    <view class="case-card" wx:for="{{recentCases}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="case-cover">
        <image wx:if="{{item.coverImageUrl}}" class="cover-image" src="{{item.coverImageUrl}}" mode="aspectFill" />
        <view wx:if="{{item.coverImageUrl}}" class="cover-overlay"></view>
        <view wx:else class="cover-placeholder {{item.coverTheme}}">
          <view class="cover-badge">{{item.coverBadge}}</view>
          <view class="cover-title">{{item.title}}</view>
          <view class="cover-caption">{{item.address}}</view>
        </view>
      </view>
      <view class="case-body">
        <view class="case-topline">
          <view class="case-title">{{item.title}}</view>
          <view class="inline-tag">{{item.completedAt}}</view>
        </view>
        <view class="case-address">{{item.address}}</view>
        <view class="meta-row">
          <view class="meta-tag">{{item.houseTypeLabel}}</view>
          <view class="meta-tag">{{item.materialLabel}}</view>
          <view class="meta-tag">{{item.areaLabel}}</view>
        </view>
        <view class="divider"></view>
        <view class="section-subtitle">适合直接分享给关注 {{item.materialLabel}}、{{item.houseTypeLabel}} 的客户。</view>
      </view>
    </view>

    <view class="button-row">
      <button class="btn" bindtap="goList">查看全部案例</button>
    </view>
  </view>
</view>
